# Application timezone (IANA). All due dates and timestamps use this zone.
# APP_TIMEZONE=Africa/Johannesburg

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production
SESSION_SECRET_KEY=your-session-secret-key-here

# Database Configuration
# Default is SQLite: app/edumind_ai.db (auto-created).
#
# For a 3-tier setup (DB on different machine), use a remote Postgres URL:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# DATABASE_URL=
#
# Optional override for SQLite file path:
# SQLITE_DB_PATH=/app/data/edumind_ai.db

# NVIDIA API Key for AI features (optional)
# Using OpenRouter - Get from https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Local AI (Ollama) alternative (optional)
# If OLLAMA_BASE_URL is set, the app will use Ollama for /ai features instead of OpenRouter.
# Install: https://ollama.com
# Run: ollama serve
# Pull a model: ollama pull llama3.2
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2

# Email Configuration (for password reset and email verification)
# For Gmail: use smtp.gmail.com, port 587, TLS enabled
# For other providers: check your provider's SMTP settings
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@edumindai.com
